generator client {
  provider = "prisma-client-js"
}

datasource db {
  //  force redeploy
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        Int        @id @default(autoincrement())
  email                     String     @unique
  password                  String
  isVerified                Boolean    @default(false)
  verificationCode          String?
  verificationCodeExpiresAt DateTime?
  therapist                 Therapist?
}

model Therapist {
  id        Int                 @id @default(autoincrement())
  firstName String
  lastName  String
  userId    Int                 @unique
  phone     String?
  gender    String?
  birthDate DateTime?
  clients   Client[]
  services  Service[]
  user      User                @relation(fields: [userId], references: [id])
  locations TherapistLocation[]
  settings  TherapistSettings?
  appointments Appointment[]
}

model TherapistLocation {
  id          Int       @id @default(autoincrement())
  therapistId Int
  name        String
  country     String
  city        String
  address     String
  therapist   Therapist @relation(fields: [therapistId], references: [id])
}

model Service {
  id          Int       @id @default(autoincrement())
  name        String
  therapistId Int
  therapist   Therapist @relation(fields: [therapistId], references: [id])
}

model Client {
  id                    Int                @id @default(autoincrement())
  name                  String
  email                 String?
  phone                 String?
  notes                 String?
  country               String?
  city                  String?
  reminderMinutesBefore Int?
  reminderOffsets       String?
  therapistId           Int
  appointments          Appointment[]
  therapist             Therapist          @relation(fields: [therapistId], references: [id])
  pushSubscriptions     PushSubscription[]
  clientAccessToken     String @unique
  alias                 String?
}

model Appointment {
  id            Int              @id @default(autoincrement())
  startTime     DateTime
  endTime       DateTime
  clientId      Int
  therapistId   Int
  status        String           @default("scheduled")
  notes         String?
  remindersSent String?
  seriesId      Int?
  originalDate  DateTime?
  isException   Boolean          @default(false)
  isCancelled   Boolean          @default(false)
  client        Client           @relation(fields: [clientId], references: [id])
  series        RecurringSeries? @relation(fields: [seriesId], references: [id])
  messages      Message[]
  notesRelation Note[]
  therapist     Therapist @relation(fields: [therapistId], references: [id])
}

model Note {
  id            Int         @id @default(autoincrement())
  content       String
  appointmentId Int
  createdAt     DateTime    @default(now())
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
}

model Message {
  id            Int          @id @default(autoincrement())
  therapistId   Int
  clientId      Int
  appointmentId Int?
  type          String
  content       String?
  sendAt        DateTime
  sentAt        DateTime?
  status        String
  createdAt     DateTime     @default(now())
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  readAt        DateTime?

  @@index([sendAt, status])
  @@index([type])
}

model TherapistSettings {
  id              Int       @id @default(autoincrement())
  therapistId     Int       @unique
  reminderOffsets String
  retentionMonths Int       @default(12)
  therapist       Therapist @relation(fields: [therapistId], references: [id])
}

model PushSubscription {
  id       Int    @id @default(autoincrement())
  clientId Int
  endpoint String @unique
  p256dh   String
  auth     String
  client   Client @relation(fields: [clientId], references: [id])
}

model RecurringSeries {
  id           Int           @id @default(autoincrement())
  clientId     Int
  therapistId  Int
  startTime    DateTime
  endTime      DateTime
  frequency    String
  interval     Int
  daysOfWeek   String
  until        DateTime?
  createdAt    DateTime      @default(now())
  appointments Appointment[]
}
